#:kivy 2.0
#:import dp kivy.metrics.dp

<ConnectionListScreen>:
    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            id: toolbar
            title: 'Watcher -- Connections'
            right_action_items: [['plus', lambda x: root.new_connection(), 'New Connection']]

        MDBoxLayout:
            orientation: 'vertical'
            padding: dp(10)
            spacing: dp(10)

            ScrollView:
                MDBoxLayout:
                    id: button_layout
                    orientation: 'vertical'
                    size_hint_y: None
                    spacing: dp(5)
                    height: self.minimum_height

<NewConnectionScreen>:
    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            id: toolbar
            title: 'New Connection'
            left_action_items: [['arrow-left', lambda x: root.go_back()]]

        MDBoxLayout:
            orientation: 'vertical'
            padding: dp(10)
            spacing: dp(10)

            MDBoxLayout:
                size_hint_y: 0.08
                spacing: dp(5)

                MDLabel:
                    text: 'Name:'
                    size_hint_x: 0.3
                    font_style: 'Body1'

                MDTextField:
                    id: conn_name
                    size_hint_x: 0.7

            MDBoxLayout:
                size_hint_y: 0.08
                spacing: dp(5)

                MDLabel:
                    text: 'Router Type:'
                    size_hint_x: 0.3
                    font_style: 'Body1'

                Spinner:
                    id: router_type
                    text: 'ddwrt'
                    values: ['ddwrt', 'ddwrt_v3_netgear_r7000', 'mock']
                    size_hint_x: 0.7
                    font_size: '14sp'
                    on_text: root.on_router_type_change(self, args[1])

            MDBoxLayout:
                size_hint_y: 0.08
                spacing: dp(5)

                MDLabel:
                    text: 'IP Address:'
                    size_hint_x: 0.3
                    font_style: 'Body1'

                MDTextField:
                    id: conn_ip
                    size_hint_x: 0.7

            MDBoxLayout:
                size_hint_y: 0.08
                spacing: dp(5)

                MDLabel:
                    text: 'Port:'
                    size_hint_x: 0.3
                    font_style: 'Body1'

                MDTextField:
                    id: conn_port
                    size_hint_x: 0.7
                    text: '22'
                    input_filter: 'int'

            MDBoxLayout:
                size_hint_y: 0.08
                spacing: dp(5)

                MDLabel:
                    text: 'Username:'
                    size_hint_x: 0.3
                    font_style: 'Body1'

                MDTextField:
                    id: conn_username
                    size_hint_x: 0.7

            MDBoxLayout:
                size_hint_y: 0.12
                spacing: dp(10)

                MDRaisedButton:
                    text: 'Save'
                    on_press: root.save_connection()

                MDFlatButton:
                    text: 'Cancel'
                    on_press: root.go_back()

<StatusScreen>:
    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            id: toolbar
            title: ''
            left_action_items: [['arrow-left', lambda x: root.go_back()]]

        MDBoxLayout:
            orientation: 'vertical'
            padding: dp(10)
            spacing: dp(10)

            MDRectangleFlatButton:
                text: 'DHCP Clients'
                size_hint_y: None
                height: dp(48)
                on_press: root.show_clients()

            MDRectangleFlatButton:
                text: 'Static Leases'
                size_hint_y: None
                height: dp(48)
                on_press: root.show_leases()

            MDRectangleFlatButton:
                text: 'VLANs'
                size_hint_y: None
                height: dp(48)
                on_press: root.show_vlans()

            MDRectangleFlatButton:
                text: 'Router Config'
                size_hint_y: None
                height: dp(48)
                on_press: root.show_config()

<ConfigureScreen>:
    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            id: toolbar
            title: ''
            left_action_items: [['arrow-left', lambda x: root.go_back()]]

        MDBoxLayout:
            orientation: 'vertical'
            padding: dp(10)
            spacing: dp(10)

            MDRectangleFlatButton:
                text: 'Static Leases'
                size_hint_y: None
                height: dp(48)
                on_press: root.show_static_leases()

            MDRectangleFlatButton:
                text: 'DHCP Lease Revocation'
                size_hint_y: None
                height: dp(48)
                on_press: root.show_dhcp_revoke()

            MDRectangleFlatButton:
                text: 'VLAN Configuration'
                size_hint_y: None
                height: dp(48)
                on_press: root.show_vlan_config()

<ClientsScreen>:
    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            id: toolbar
            title: ''
            left_action_items: [['arrow-left', lambda x: root.go_back()]]

        MDBoxLayout:
            orientation: 'vertical'
            padding: dp(10)
            spacing: dp(10)

            MDBoxLayout:
                size_hint_y: None
                height: dp(40)
                spacing: dp(2)

                MDLabel:
                    text: 'MAC'
                    size_hint_x: 0.35
                    font_style: 'Subtitle2'
                    bold: True

                MDLabel:
                    text: 'IP'
                    size_hint_x: 0.30
                    font_style: 'Subtitle2'
                    bold: True

                MDLabel:
                    text: 'Hostname'
                    size_hint_x: 0.35
                    font_style: 'Subtitle2'
                    bold: True

            ScrollView:
                MDBoxLayout:
                    id: data_layout
                    orientation: 'vertical'
                    size_hint_y: None
                    spacing: dp(2)
                    height: self.minimum_height

            MDBoxLayout:
                size_hint_y: None
                height: dp(48)
                spacing: dp(10)

                MDRaisedButton:
                    text: 'Refresh'
                    on_press: root.load_data()

                MDFlatButton:
                    text: 'Back'
                    on_press: root.go_back()

