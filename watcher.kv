                    font_style: 'Subtitle2'
                    bold: True

                MDLabel:
                    text: 'IP'
                    size_hint_x: 0.30
                    font_style: 'Subtitle2'
                    bold: True

            ScrollView:
                MDBoxLayout:
                    id: data_layout
