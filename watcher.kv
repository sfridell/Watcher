#:kivy 2.0
#:import dp kivy.metrics.dp

<ConnectionListScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        Label:
            text: 'Watcher -- Connections'
            size_hint_y: 0.1
            font_size: '20sp'
            bold: True
        
        ScrollView:
            BoxLayout:
                id: button_layout
                orientation: 'vertical'
                size_hint_y: None
                spacing: dp(5)
                height: self.minimum_height

<ConnectionMenuScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        Label:
            id: title_label
            text: ''
            size_hint_y: 0.08
            font_size: '20sp'
            bold: True
        
        BoxLayout:
            orientation: 'vertical'
            spacing: dp(10)
            size_hint_y: 0.82
            
            Button:
                text: 'View DHCP Clients'
                font_size: '18sp'
                on_press: root.show_clients()
            
            Button:
                text: 'View Static Leases'
                font_size: '18sp'
                on_press: root.show_leases()
            
            Button:
                text: 'View Config'
                font_size: '18sp'
                on_press: root.show_config()
            
            Button:
                text: 'VLAN Configuration'
                font_size: '18sp'
                on_press: root.show_vlan_list()
            
            Button:
                text: 'Config Actions'
                font_size: '18sp'
                on_press: root.show_config_actions()
        
        Button:
            text: 'Back'
            size_hint_y: 0.1
            font_size: '16sp'
            on_press: root.go_back()

<ClientsScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        Label:
            id: title_label
            text: ''
            size_hint_y: 0.08
            font_size: '20sp'
            bold: True
        
        BoxLayout:
            size_hint_y: 0.08
            spacing: dp(2)
            
            Label:
                text: 'MAC'
                size_hint_x: 0.35
                bold: True
                font_size: '14sp'
            
            Label:
                text: 'IP'
                size_hint_x: 0.30
                bold: True
                font_size: '14sp'
            
            Label:
                text: 'Hostname'
                size_hint_x: 0.35
                bold: True
                font_size: '14sp'
        
        ScrollView:
            BoxLayout:
                id: data_layout
                orientation: 'vertical'
                size_hint_y: None
                spacing: dp(2)
                height: self.minimum_height
        
        BoxLayout:
            size_hint_y: 0.1
            spacing: dp(10)
            
            Button:
                text: 'Refresh'
                font_size: '16sp'
                on_press: root.load_data()
            
            Button:
                text: 'Back'
                font_size: '16sp'
                on_press: root.go_back()

<StaticLeasesScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        Label:
            id: title_label
            text: ''
            size_hint_y: 0.08
            font_size: '20sp'
            bold: True
        
        BoxLayout:
            size_hint_y: 0.08
            spacing: dp(2)
            
            Label:
                text: 'MAC'
                size_hint_x: 0.35
                bold: True
                font_size: '14sp'
            
            Label:
                text: 'Hostname'
                size_hint_x: 0.35
                bold: True
                font_size: '14sp'
            
            Label:
                text: 'IP'
                size_hint_x: 0.30
                bold: True
                font_size: '14sp'
        
        ScrollView:
            BoxLayout:
                id: data_layout
                orientation: 'vertical'
                size_hint_y: None
                spacing: dp(2)
                height: self.minimum_height
        
        BoxLayout:
            size_hint_y: 0.1
            spacing: dp(10)
            
            Button:
                text: 'Refresh'
                font_size: '16sp'
                on_press: root.load_data()
            
            Button:
                text: 'Back'
                font_size: '16sp'
                on_press: root.go_back()

<ConfigScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        Label:
            id: title_label
            text: ''
            size_hint_y: 0.08
            font_size: '20sp'
            bold: True
        
        TextInput:
            id: config_text
            size_hint_y: 0.82
            font_size: '12sp'
            readonly: True
            multiline: True
        
        BoxLayout:
            size_hint_y: 0.1
            spacing: dp(10)
            
            Button:
                text: 'Refresh'
                font_size: '16sp'
                on_press: root.load_data()
            
            Button:
                text: 'Back'
                font_size: '16sp'
                on_press: root.go_back()

<VlanListScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        Label:
            id: title_label
            text: ''
            size_hint_y: 0.08
            font_size: '20sp'
            bold: True
        
        BoxLayout:
            size_hint_y: 0.08
            spacing: dp(2)
            
            Label:
                text: 'VLAN'
                size_hint_x: 0.20
                bold: True
                font_size: '14sp'
            
            Label:
                text: 'IP'
                size_hint_x: 0.25
                bold: True
                font_size: '14sp'
            
            Label:
                text: 'Brg'
                size_hint_x: 0.10
                bold: True
                font_size: '14sp'
            
            Label:
                text: 'NAT'
                size_hint_x: 0.10
                bold: True
                font_size: '14sp'
            
            Label:
                text: 'Members'
                size_hint_x: 0.35
                bold: True
                font_size: '14sp'
        
        ScrollView:
            BoxLayout:
                id: data_layout
                orientation: 'vertical'
                size_hint_y: None
                spacing: dp(2)
                height: self.minimum_height
        
        BoxLayout:
            size_hint_y: 0.1
            spacing: dp(10)
            
            Button:
                text: 'Add VLAN'
                font_size: '16sp'
                on_press: root.add_vlan()
            
            Button:
                text: 'Refresh'
                font_size: '16sp'
                on_press: root.load_data()
            
            Button:
                text: 'Back'
                font_size: '16sp'
                on_press: root.go_back()

<VlanEditScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        Label:
            id: title_label
            text: 'Edit VLAN'
            size_hint_y: 0.08
            font_size: '20sp'
            bold: True
        
        BoxLayout:
            size_hint_y: 0.02
            spacing: dp(5)
            
            Label:
                text: 'VLAN ID:'
                size_hint_x: 0.4
                font_size: '14sp'
            
            TextInput:
                id: vlan_id
                size_hint_x: 0.6
                font_size: '14sp'
                input_filter: 'int'
        
        BoxLayout:
            size_hint_y: 0.02
            spacing: dp(5)
            
            Label:
                text: 'IP Address:'
                size_hint_x: 0.4
                font_size: '14sp'
            
            TextInput:
                id: vlan_ip
                size_hint_x: 0.6
                font_size: '14sp'
        
        BoxLayout:
            size_hint_y: 0.02
            spacing: dp(5)
            
            Label:
                text: 'Netmask:'
                size_hint_x: 0.4
                font_size: '14sp'
            
            TextInput:
                id: vlan_netmask
                size_hint_x: 0.6
                font_size: '14sp'
        
        BoxLayout:
            size_hint_y: 0.02
            spacing: dp(5)
            
            Label:
                text: 'Bridged:'
                size_hint_x: 0.4
                font_size: '14sp'
            
            CheckBox:
                id: vlan_bridged
        
        BoxLayout:
            size_hint_y: 0.02
            spacing: dp(5)
            
            Label:
                text: 'NAT:'
                size_hint_x: 0.4
                font_size: '14sp'
            
            CheckBox:
                id: vlan_nat
        
        BoxLayout:
            size_hint_y: 0.02
            spacing: dp(5)
            
            Label:
                text: 'DHCP Enabled:'
                size_hint_x: 0.4
                font_size: '14sp'
            
            CheckBox:
                id: vlan_dhcp_enabled
        
        BoxLayout:
            size_hint_y: 0.02
            spacing: dp(5)
            
            Label:
                text: 'DHCP Start:'
                size_hint_x: 0.4
                font_size: '14sp'
            
            TextInput:
                id: vlan_dhcp_start
                size_hint_x: 0.6
                font_size: '14sp'
                input_filter: 'int'
        
        BoxLayout:
            size_hint_y: 0.02
            spacing: dp(5)
            
            Label:
                text: 'DHCP Size:'
                size_hint_x: 0.4
                font_size: '14sp'
            
            TextInput:
                id: vlan_dhcp_size
                size_hint_x: 0.6
                font_size: '14sp'
                input_filter: 'int'
        
        BoxLayout:
            size_hint_y: 0.02
            spacing: dp(5)
            
            Label:
                text: 'DHCP Lease (min):'
                size_hint_x: 0.4
                font_size: '14sp'
            
            TextInput:
                id: vlan_dhcp_lease
                size_hint_x: 0.6
                font_size: '14sp'
                input_filter: 'int'
        
        BoxLayout:
            size_hint_y: 0.1
            spacing: dp(10)
            
            Button:
                text: 'Save'
                font_size: '16sp'
                on_press: root.save_vlan()
            
            Button:
                text: 'Cancel'
                font_size: '16sp'
                on_press: root.go_back()

<ConfigActionsScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        Label:
            id: title_label
            text: ''
            size_hint_y: 0.06
            font_size: '20sp'
            bold: True
        
        BoxLayout:
            size_hint_y: 0.06
            spacing: dp(5)
            
            Label:
                text: 'File path:'
                size_hint_x: 0.3
                font_size: '12sp'
            
            TextInput:
                id: file_path
                size_hint_x: 0.7
                font_size: '12sp'
        
        BoxLayout:
            size_hint_y: 0.06
            spacing: dp(5)
            
            Label:
                text: 'Apply mode:'
                size_hint_x: 0.3
                font_size: '12sp'
            
            Spinner:
                id: apply_mode
                text: 'diff'
                values: ['diff', 'full']
                size_hint_x: 0.7
                font_size: '12sp'
        
        BoxLayout:
            size_hint_y: 0.15
            spacing: dp(5)
            
            Button:
                text: 'Snapshot'
                font_size: '12sp'
                on_press: root.snapshot()
            
            Button:
                text: 'Load'
                font_size: '12sp'
                on_press: root.load_file()
            
            Button:
                text: 'Save'
                font_size: '12sp'
                on_press: root.save_file()
        
        BoxLayout:
            size_hint_y: 0.15
            spacing: dp(5)
            
            Button:
                text: 'Validate'
                font_size: '12sp'
                on_press: root.validate()
            
            Button:
                text: 'Diff'
                font_size: '12sp'
                on_press: root.diff_router()
            
            Button:
                text: 'Apply'
                font_size: '12sp'
                on_press: root.apply_config()
            
            Button:
                text: 'Verify'
                font_size: '12sp'
                on_press: root.verify_config()
        
        TextInput:
            id: result_text
            size_hint_y: 0.42
            font_size: '10sp'
            readonly: False
            multiline: True
        
        Button:
            text: 'Back'
            size_hint_y: 0.1
            font_size: '16sp'
            on_press: root.go_back()

<PortAssignScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        Label:
            id: title_label
            text: 'Port Assignments'
            size_hint_y: 0.08
            font_size: '20sp'
            bold: True
        
        ScrollView:
            BoxLayout:
                id: port_layout
                orientation: 'vertical'
                size_hint_y: None
                spacing: dp(2)
                height: self.minimum_height
        
        BoxLayout:
            size_hint_y: 0.1
            spacing: dp(10)
            
            Button:
                text: 'Back'
                font_size: '16sp'
                on_press: root.go_back()

<ConnectionButton@Button>:
    size_hint_y: None
    height: dp(50)
    font_size: '18sp'

<DataRow@BoxLayout>:
    size_hint_y: None
    height: dp(40)
    spacing: dp(2)