<ConfigScreen>:
    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            id: toolbar
            title: ''
            left_action_items: [['arrow-left', lambda x: root.go_back()]]

        MDBoxLayout:
            orientation: 'vertical'
            padding: dp(10)
            spacing: dp(10)

            MDTextField:
                id: config_text
                size_hint_y: 0.82
                readonly: True
                multiline: True

            MDBoxLayout:
                size_hint_y: None
                height: dp(48)
                spacing: dp(10)

                MDRaisedButton:
                    text: 'Refresh'
                    on_press: root.load_data()

                MDFlatButton:
                    text: 'Back'
                    on_press: root.go_back()

<VlanListScreen>:
    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            id: toolbar
            title: ''
            left_action_items: [['arrow-left', lambda x: root.go_back()]]

        MDBoxLayout:
            orientation: 'vertical'
            padding: dp(10)
            spacing: dp(10)

            FloatLayout:
                id: canvas_layout
                size_hint_y: 0.82

            MDBoxLayout:
                size_hint_y: None
                height: dp(48)
                spacing: dp(10)

                MDRaisedButton:
                    text: 'Refresh'
                    on_press: root.load_data()

                MDFlatButton:
                    text: 'Back'
                    on_press: root.go_back()

<ConfigureStaticLeasesScreen>:
    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            id: toolbar
            title: ''
            left_action_items: [['arrow-left', lambda x: root.go_back()]]

        MDBoxLayout:
            orientation: 'vertical'
            padding: dp(10)
            spacing: dp(10)

            MDLabel:
                id: status_label
                text: ''
                size_hint_y: None
                height: dp(20)
                font_style: 'Caption'
                theme_text_color: 'Secondary'

            MDBoxLayout:
                size_hint_y: None
                height: dp(30)
                spacing: dp(1)

                MDLabel:
                    text: 'MAC'
                    size_hint_x: 0.33
                    font_style: 'Caption'
                    bold: True

                MDLabel:
                    text: 'Hostname'
                    size_hint_x: 0.30
                    font_style: 'Caption'
                    bold: True

                MDLabel:
                    text: 'IP'
                    size_hint_x: 0.27
                    font_style: 'Caption'
                    bold: True

                MDLabel:
                    text: 'Del'
                    size_hint_x: 0.10
                    font_style: 'Caption'
                    bold: True

            ScrollView:
                MDBoxLayout:
                    id: data_layout
                    orientation: 'vertical'
                    size_hint_y: None
                    spacing: dp(1)
                    height: self.minimum_height

            MDBoxLayout:
                size_hint_y: None
                height: dp(40)
                spacing: dp(1)

                MDTextField:
                    id: new_mac
                    size_hint_x: 0.33
                    hint_text: 'MAC'

                MDTextField:
                    id: new_hostname
                    size_hint_x: 0.30
                    hint_text: 'Hostname'

                MDTextField:
                    id: new_ip
                    size_hint_x: 0.27
                    hint_text: 'IP'

                MDRaisedButton:
                    text: '+'
                    size_hint_x: 0.10
                    on_press: root.add_lease()

            MDBoxLayout:
                size_hint_y: None
                height: dp(48)
                spacing: dp(10)

                MDRaisedButton:
                    text: 'Refresh'
                    on_press: root.refresh_data()

                MDRaisedButton:
                    text: 'Commit'
                    on_press: root.commit_changes()

                MDFlatButton:
                    text: 'Back'
                    on_press: root.go_back()

<ConfigureDhcpScreen>:
    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            id: toolbar
            title: ''
            left_action_items: [['arrow-left', lambda x: root.go_back()]]

        MDBoxLayout:
            orientation: 'vertical'
            padding: dp(10)
            spacing: dp(10)

            MDBoxLayout:
                size_hint_y: None
                height: dp(30)
                spacing: dp(1)

                MDLabel:
                    text: ''
                    size_hint_x: 0.10
                    font_style: 'Caption'

                MDLabel:
                    text: 'MAC'
                    size_hint_x: 0.30
                    font_style: 'Caption'
                    bold: True

                MDLabel:
                    text: 'IP'
                    size_hint_x: 0.30
                    font_style: 'Caption'
                    bold: True

                MDLabel:
                    text: 'Hostname'
                    size_hint_x: 0.30
                    font_style: 'Caption'
                    bold: True

            ScrollView:
                MDBoxLayout:
                    id: data_layout
                    orientation: 'vertical'
                    size_hint_y: None
                    spacing: dp(1)
                    height: self.minimum_height

            MDBoxLayout:
                size_hint_y: None
                height: dp(48)
                spacing: dp(10)

                MDRaisedButton:
                    text: 'Refresh'
                    on_press: root.load_data()

                MDRaisedButton:
                    text: 'Revoke Selected'
                    on_press: root.revoke_selected()

                MDFlatButton:
                    text: 'Back'
                    on_press: root.go_back()

<ConfigureVlanScreen>:
    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            id: toolbar
            title: ''
            left_action_items: [['arrow-left', lambda x: root.go_back()]]

        FloatLayout:
            id: canvas_layout
            size_hint_y: 3.0

        MDBoxLayout:
            orientation: 'vertical'
            padding: dp(10)
            spacing: dp(8)

            MDLabel:
                id: status_label
                text: 'No config loaded - take a snapshot first'
                size_hint_y: None
                height: dp(24)
                font_style: 'Caption'
                theme_text_color: 'Custom'
                color: (0.8, 0.4, 0.1, 1)

            MDBoxLayout:
                size_hint_y: None
                height: dp(48)
                spacing: dp(10)

                MDRaisedButton:
                    text: 'Snapshot'
                    on_press: root.snapshot()

                MDIconButton:
                    icon: 'plus'
                    on_press: root.add_vlan()

                MDRaisedButton:
                    text: 'Commit'
                    on_press: root.commit_changes()

                MDFlatButton:
                    text: 'Back'
                    on_press: root.go_back()

<VlanEditScreen>:
    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            id: toolbar
            title: 'Edit VLAN'
            left_action_items: [['arrow-left', lambda x: root.go_back()]]

        MDBoxLayout:
            orientation: 'vertical'
            padding: dp(10)
            spacing: dp(10)

            MDBoxLayout:
                size_hint_y: None
                height: dp(56)
                spacing: dp(5)

                MDLabel:
                    text: 'VLAN ID:'
                    size_hint_x: 0.4
                    font_style: 'Body1'

                MDTextField:
                    id: vlan_id
                    size_hint_x: 0.6
                    input_filter: 'int'

            MDBoxLayout:
                size_hint_y: None
                height: dp(56)
                spacing: dp(5)

                MDLabel:
                    text: 'IP Address:'
                    size_hint_x: 0.4
                    font_style: 'Body1'

                MDTextField:
                    id: vlan_ip
                    size_hint_x: 0.6

            MDBoxLayout:
                size_hint_y: None
                height: dp(56)
                spacing: dp(5)

                MDLabel:
                    text: 'Netmask:'
                    size_hint_x: 0.4
                    font_style: 'Body1'

                MDTextField:
                    id: vlan_netmask
                    size_hint_x: 0.6

            MDBoxLayout:
                size_hint_y: None
                height: dp(56)
                spacing: dp(5)

                MDLabel:
                    text: 'Bridged:'
                    size_hint_x: 0.4
                    font_style: 'Body1'

                MDCheckbox:
                    id: vlan_bridged

            MDBoxLayout:
                size_hint_y: None
                height: dp(56)
                spacing: dp(5)

                MDLabel:
                    text: 'NAT:'
                    size_hint_x: 0.4
                    font_style: 'Body1'

                MDCheckbox:
                    id: vlan_nat

            MDBoxLayout:
                size_hint_y: None
                height: dp(56)
                spacing: dp(5)

                MDLabel:
                    text: 'DHCP Enabled:'
                    size_hint_x: 0.4
                    font_style: 'Body1'

                MDCheckbox:
                    id: vlan_dhcp_enabled

            MDBoxLayout:
                size_hint_y: None
                height: dp(56)
                spacing: dp(5)

                MDLabel:
                    text: 'DHCP Start:'
                    size_hint_x: 0.4
                    font_style: 'Body1'

                MDTextField:
                    id: vlan_dhcp_start
                    size_hint_x: 0.6
                    input_filter: 'int'

            MDBoxLayout:
                size_hint_y: None
                height: dp(56)
                spacing: dp(5)

                MDLabel:
                    text: 'DHCP Size:'
                    size_hint_x: 0.4
                    font_style: 'Body1'

                MDTextField:
                    id: vlan_dhcp_size
                    size_hint_x: 0.6
                    input_filter: 'int'

            MDBoxLayout:
                size_hint_y: None
                height: dp(56)
                spacing: dp(5)

                MDLabel:
                    text: 'DHCP Lease (min):'
                    size_hint_x: 0.4
                    font_style: 'Body1'

                MDTextField:
                    id: vlan_dhcp_lease
                    size_hint_x: 0.6
                    input_filter: 'int'

            MDBoxLayout:
                size_hint_y: None
                height: dp(48)
                spacing: dp(10)

                MDRaisedButton:
                    text: 'Save'
                    on_press: root.save_vlan()

                MDRaisedButton:
                    id: delete_button
                    text: 'Delete'
                    on_press: root.delete_vlan()

                MDFlatButton:
                    text: 'Cancel'
                    on_press: root.go_back()
